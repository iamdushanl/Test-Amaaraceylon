# Authentication
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_AUTH_ENABLED=true

# Database
DATABASE_URL=

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=3600

# Email
EMAIL_PROVIDER=
EMAIL_FROM=noreply@amaara.com
SENDGRID_API_KEY=

# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# File Upload
NEXT_PUBLIC_UPLOAD_MAX_SIZE=5242880
NEXT_PUBLIC_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
